@model List<Repo>

<script src="https://cdn.tailwindcss.com"></script>

<div class="flex flex-wrap justify-center gap-6">
    @* Sidebar *@
    <div class="h-[600px] w-[400px] bg-gray-900 p-6 rounded-2xl ">
        <div class="text-2xl mb-5">Utilities</div>
        <div class="flex flex-col space-y-2">
            <a asp-controller="GitHub" asp-action="Index">Search Repo</a>
            <a asp-controller="Favorites" asp-action="Index">Favorites</a>
            <a asp-controller="History" asp-action="Index">History</a>
            <a class="text-red-400 hover:text-red-600" asp-controller="Account" asp-action="Login">Logout</a>
        </div>
    </div>

    @* Main Body *@
    <div class="h-[600px] w-[1000px] bg-gray-900 text-gray-100 p-6 rounded-2xl">
	    <h2 class="text-3xl font-bold text-gray-100 mb-4">Repositories</h2>

        <div class="mb-6 flex items-center gap-2">
            <form method="get" class="flex gap-2 items-center">
                <input type="text" name="username" placeholder="Enter GitHub username"
                       value="@ViewBag.SearchText"
                       class="px-4 py-2 rounded bg-gray-800 text-gray-100 border border-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500" />
                <button type="submit"
                        class="px-4 py-2 rounded bg-blue-600 text-white hover:bg-blue-700">
                    Search
                </button>
            </form>


            <form asp-action="ToggleFavorite" asp-route-id="@ViewBag.CurrentRepoId" method="post" class="flex items-center">
                <button type="submit" class="bg-transparent border-none cursor-pointer">
                    @if ((bool)(ViewBag.IsFavorite ?? false))
                    {
                        <span class="text-yellow-400 text-3xl">&#9733;</span> <!-- solid star -->
                    }
                    else
                    {
                        <span class="text-gray-400 text-3xl">&#9734;</span> <!-- hollow star -->
                    }
                </button>
            </form>
        </div>


        <div class="h-[425px] overflow-y-scroll [scrollbar-width:none] [-ms-overflow-style:none]">


            @if (ViewBag.ErrorMessage != null)
            {
                <div class="text-red-500 font-bold mb-4">@ViewBag.ErrorMessage</div>
            }

            <table class="min-w-full">
                <thead class="bg-gray-800 text-gray-100">
                    <tr>
                        <th>Name</th>
                        <th>Stars</th>
                        <th>Language</th>
                        <th>Link</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var repo in Model)
                    {
                        <tr class="hover:bg-gray-700">
                            <td>@repo.Name</td>
                            <td>@repo.Stargazers_count</td>
                            <td>@repo.Language</td>
                            <td>
                                <a href="@repo.Html_url" target="_blank" class="text-blue-400 hover:underline">View</a>
                            </td>
                            <td>
                                @{
                                    bool hasNotes = ((List<Note>)ViewBag.RepoNotes)
                                        .Any(n => n.RepoName == repo.Name);
                                    var linkClass = hasNotes ? "text-blue-400 hover:underline" : "text-green-400 hover:underline";
                                }
                                <a asp-controller="Notes" asp-action="Index" asp-route-repoName="@repo.Name" class="@linkClass">Notes</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>