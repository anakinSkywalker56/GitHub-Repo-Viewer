@model List<Favorite>

<script src="https://cdn.tailwindcss.com"></script>

<div class="flex flex-wrap justify-center gap-6">
    @* Sidebar *@
    <div class="h-[600px] w-[400px] bg-gray-900 p-6 rounded-2xl ">
        <div class="text-2xl mb-5">Utilities</div>
        <div class="flex flex-col space-y-2">
            <a asp-controller="GitHub" asp-action="Index">Search Repo</a>
            <a asp-controller="Favorites" asp-action="Index">Favorites</a>
            <a asp-controller="History" asp-action="Index">History</a>
            <a class="text-red-400 hover:text-red-600" asp-controller="Account" asp-action="Login">Logout</a>

        </div>
    </div>

    @* Main Body *@
    <div class="h-[600px] w-[1000px] bg-gray-900 text-gray-100 p-6 rounded-2xl">

        <h2 class="text-3xl font-bold mb-4">Favorites</h2>

        <table class="min-w-full bg-gray-800 text-gray-100 rounded">
            <thead>
                <tr>
                    <th class="px-4 py-2 text-left">GitHub User</th>
                    <th class="px-4 py-2 text-left">Un-Fav :(</th>
                    <th class="px-4 py-2 text-left">View</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var fav in Model)
                {
                    <tr class="hover:bg-gray-700">
                        <td class="px-4 py-2">@fav.TargetUser</td>
                        <td class="px-4 py-2">
                            <form asp-action="Delete" asp-route-id="@fav.Id" method="post">
                                <button type="submit" class="text-red-400 hover:text-red-600">Remove</button>
                            </form>
                        </td>
                        <td class="px-4 py-2">
                            <a asp-controller="GitHub" asp-action="Index" asp-route-username="@fav.TargetUser"
                               class="text-blue-400 hover:underline">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>