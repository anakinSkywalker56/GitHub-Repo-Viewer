 <!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GitHubRepoViewer</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GitHubRepoViewer.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />

</head>
<body class="flex flex-col min-h-screen bg-[#0d1117] text-[#c9d1d9]">
    <header class="flex-shrink-0">
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm border-b border-[#30363d] bg-[#0d1117]">
            <div class="container-fluid">
                <a class="navbar-brand text-[#f0f6fc]" asp-area="" asp-controller="Account" asp-action="Login">
                    GitHub Repo Viewer
                </a>
                <button class="navbar-toggler text-[#f0f6fc]" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-[#f0f6fc] hover:text-[#58a6ff]" asp-area="" asp-controller="Account" asp-action="Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-[#f0f6fc] hover:text-[#58a6ff]" asp-area="" asp-controller="Account" asp-action="Register">Register</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- This section will auto-fill the space between header and footer -->
    <main role="main" class="flex-1 flex justify-center items-center">
        @RenderBody()
    </main>

    <footer class="footer border-t border-[#30363d] bg-[#0d1117] text-[#c9d1d9] py-3 flex-shrink-0">
        <div class="container">
            &copy; 2026 - GitHubRepoViewer -
            <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-[#58a6ff] hover:underline">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
